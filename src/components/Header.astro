---
import { tagline } from '../data/contact';
import { link } from '../lib/url';

const navLinks = [
  { href: link('/'), label: 'Home' },
  { href: link('/about'), label: 'About' },
  { href: link('/services'), label: 'Services' },
  { href: link('/gallery'), label: 'Gallery' },
  { href: link('/contact'), label: 'Contact' },
];
---

<header class="sticky top-0 z-50 bg-navy-dark shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href={link('/')} class="flex items-center gap-3">
        <img src={link('/img/logo-mj.jpg')} alt="M & J Masonry" class="h-12 w-12 rounded-full object-cover" />
        <div>
          <span class="text-xl font-heading font-bold text-white">M &amp; J Masonry</span>
          <span class="hidden lg:block text-xs text-gold tracking-wide">{tagline}</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-gray-300 hover:text-gold font-medium transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
        <a
          href={link('/contact')}
          class="hidden lg:inline-block whitespace-nowrap bg-gold hover:bg-gold-bright text-navy-dark font-bold px-6 py-3 rounded-lg transition-colors duration-200 shadow-md"
        >
          Get Your Free Estimate
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-white p-2"
        aria-label="Toggle menu"
      >
        <svg id="menu-icon-open" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-7 h-7 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden bg-navy-dark border-t border-navy-light">
    <div class="px-4 py-4 space-y-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block text-gray-300 hover:text-gold font-medium py-2 transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href={link('/contact')}
        class="block text-center bg-gold hover:bg-gold-bright text-navy-dark font-bold px-6 py-3 rounded-lg transition-colors mt-4"
      >
        Get Your Free Estimate
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
