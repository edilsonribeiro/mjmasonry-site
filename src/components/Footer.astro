---
import {
  phoneDisplay,
  email,
  locationCity,
  tagline,
  callLink,
  smsLink,
  whatsappLink,
  mailtoLink,
} from '../data/contact';
import { link } from '../lib/url';

const currentYear = new Date().getFullYear();
---

<footer class="bg-navy-dark text-gray-300">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <img src={link('/img/logo-mj.png')} alt="M & J Masonry" class="h-24 w-auto object-contain mb-4" />
        <p class="text-gold font-medium mb-4">{tagline}</p>
        <p class="text-sm leading-relaxed">
          Family-owned masonry and hardscape company serving Rockland, MA and the South Shore.
          We take pride in every stone we lay and every wall we build.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-heading font-bold text-lg mb-4">Quick Links</h3>
        <ul class="space-y-2">
          <li><a href={link('/')} class="hover:text-gold transition-colors">Home</a></li>
          <li><a href={link('/about')} class="hover:text-gold transition-colors">About Us</a></li>
          <li><a href={link('/services')} class="hover:text-gold transition-colors">Services</a></li>
          <li><a href={link('/gallery')} class="hover:text-gold transition-colors">Gallery</a></li>
          <li><a href={link('/contact')} class="hover:text-gold transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-white font-heading font-bold text-lg mb-4">Contact Us</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={callLink} class="hover:text-gold transition-colors">{phoneDisplay}</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
            </svg>
            <a href={smsLink} class="hover:text-gold transition-colors">Text us</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.555-5.338 11.891-11.893 11.891a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z" />
            </svg>
            <a href={whatsappLink} target="_blank" rel="noopener" class="hover:text-gold transition-colors">WhatsApp</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={mailtoLink} class="hover:text-gold transition-colors break-all">{email}</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{locationCity}</span>
          </li>
        </ul>

        <a
          href={link('/contact')}
          class="inline-block mt-6 bg-gold hover:bg-gold-bright text-navy-dark font-bold px-6 py-3 rounded-lg transition-colors shadow-md"
        >
          Get Your Free Estimate
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-navy-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 text-center text-sm">
      <p>&copy; {currentYear} M &amp; J Masonry. All rights reserved. Rockland, MA.</p>
    </div>
  </div>
</footer>
