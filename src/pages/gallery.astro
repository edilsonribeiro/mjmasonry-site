---
import Layout from '../layouts/Layout.astro';
import Pic from '../components/Pic.astro';
import { callLink, phoneDisplay } from '../data/contact';
import { link } from '../lib/url';
import { galleryCategories } from '../data/gallery';
---

<Layout
  title="Project Gallery — Patios, Walkways & Stone Work"
  description="Browse real M & J Masonry projects across the South Shore, MA: paver patios, stone walkways, retaining walls, fireplaces, and chimney work. See our craftsmanship."
>
  <!-- Page Header -->
  <section class="bg-navy-dark py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-gold font-medium uppercase tracking-widest text-sm mb-2">Our Work</p>
      <h1 class="font-heading font-extrabold text-4xl md:text-5xl text-white mb-4">
        Project Gallery
      </h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">
        See the quality and craftsmanship behind every M &amp; J Masonry project. From walkways
        to walls, each photo tells the story of hard work and attention to detail.
      </p>
    </div>
  </section>

  <!-- Category Nav -->
  <section class="bg-navy py-6 sticky top-16 z-30 border-b border-navy-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap justify-center gap-3">
        {galleryCategories.map((cat) => (
          <a
            href={`#${cat.id}`}
            class="bg-navy-dark hover:bg-gold hover:text-navy-dark text-gray-200 text-sm font-medium px-4 py-2 rounded-full transition-colors border border-navy-light hover:border-gold"
          >
            {cat.title}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery by Category -->
  <section class="py-20 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-20">
      {galleryCategories.map((cat) => (
        <div id={cat.id} class="scroll-mt-32">
          <div class="text-center mb-10">
            <h2 class="font-heading font-bold text-3xl md:text-4xl text-navy mb-3">{cat.title}</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">{cat.description}</p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {cat.images.map((img) => (
              <div class="group relative rounded-xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300 bg-white">
                <Pic
                  src={img.src}
                  alt={img.alt}
                  class="w-full h-80 object-cover group-hover:scale-105 transition-transform duration-500"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-navy-dark/85 via-navy-dark/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <div class="absolute bottom-0 left-0 right-0 p-6">
                    <span class="inline-block bg-gold text-navy-dark text-xs font-bold px-3 py-1 rounded-full mb-2">
                      {cat.title}
                    </span>
                    <p class="text-white font-medium leading-snug">{img.alt}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}

      <div class="text-center pt-8">
        <p class="text-gray-600 text-lg mb-4">
          Want to see more? New projects are added regularly as we complete work across the South Shore.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-dark py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-white mb-4">
        Like What You See?
      </h2>
      <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">
        Let us bring this level of craftsmanship to your property. Reach out for a free estimate today.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={callLink}
          class="bg-gold hover:bg-gold-bright text-navy-dark font-bold text-lg px-8 py-4 rounded-lg transition-colors shadow-lg"
        >
          Call {phoneDisplay}
        </a>
        <a
          href={link('/contact')}
          class="border-2 border-gold text-gold hover:bg-gold hover:text-navy-dark font-bold text-lg px-8 py-4 rounded-lg transition-colors"
        >
          Request a Free Estimate
        </a>
      </div>
    </div>
  </section>
</Layout>
