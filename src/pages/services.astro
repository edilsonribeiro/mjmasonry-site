---
import Layout from '../layouts/Layout.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import { link } from '../lib/url';
import { services } from '../data/services';
---

<Layout title="Services">
  <!-- Page Header -->
  <section class="bg-navy-dark py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-gold font-medium uppercase tracking-widest text-sm mb-2">What We Do</p>
      <h1 class="font-heading font-extrabold text-4xl md:text-5xl text-white mb-4">
        Our Services
      </h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">
        From stone walls to complete outdoor transformations, M &amp; J Masonry delivers
        craftsmanship you can trust — built to withstand New England weather and the test of time.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-12">
        {services.map((svc, i) => (
          <div class={`flex flex-col md:flex-row gap-8 items-center ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
            <div class="flex-1">
              <div class="bg-white rounded-xl p-8 shadow-md border border-gray-100 hover:shadow-xl transition-shadow duration-300">
                <div class="text-gold mb-4">
                  <ServiceIcon name={svc.icon} class="w-14 h-14" />
                </div>
                <h2 class="font-heading font-bold text-2xl text-navy mb-4">{svc.title}</h2>
                <p class="text-gray-700 leading-relaxed">{svc.long}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gold py-14">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-navy-dark mb-4">
        Need a Custom Solution?
      </h2>
      <p class="text-navy/80 text-lg mb-8 max-w-2xl mx-auto">
        Every property is different. Contact us for a free on-site consultation and estimate
        tailored to your project.
      </p>
      <a
        href={link('/contact')}
        class="inline-block bg-navy-dark hover:bg-navy text-white font-bold text-lg px-10 py-4 rounded-lg transition-colors shadow-lg"
      >
        Get Your Free Estimate
      </a>
    </div>
  </section>
</Layout>
