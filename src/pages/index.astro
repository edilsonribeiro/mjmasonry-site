---
import Layout from '../layouts/Layout.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import { callLink, phoneDisplay } from '../data/contact';
import { link } from '../lib/url';
import { services } from '../data/services';

const galleryImages = [
  { src: '/img/gallery/paver-walkway-fork.jpg', alt: 'Paver walkway with fork design' },
  { src: '/img/gallery/cobblestone-walkway.jpg', alt: 'Cobblestone walkway' },
  { src: '/img/gallery/paver-walkway-night.jpg', alt: 'Paver walkway at night' },
  { src: '/img/gallery/ig-post1-steps.png', alt: 'Stone steps project' },
];
---

<Layout title="Home">
  <!-- ============ HERO ============ -->
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img
        src={link('/img/carousel/hero-walkway-fork.jpg')}
        alt="Beautiful paver walkway by M & J Masonry"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-navy-dark/70"></div>
    </div>

    <!-- Hero content -->
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <p class="text-gold font-medium text-lg md:text-xl mb-4 tracking-wide uppercase">
        Rockland, MA &mdash; South Shore
      </p>
      <h1 class="font-heading font-extrabold text-4xl sm:text-5xl md:text-7xl text-white leading-tight mb-6">
        Built by Family.<br />Built to Last.
      </h1>
      <p class="text-gray-200 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
        M &amp; J Masonry delivers expert hardscape and masonry craftsmanship to homeowners across
        the South Shore. From stone walls to stunning patios, we build it right the first time.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={link('/contact')}
          class="bg-gold hover:bg-gold-bright text-navy-dark font-bold text-lg px-8 py-4 rounded-lg transition-colors shadow-lg"
        >
          Get Your Free Estimate
        </a>
        <a
          href={link('/services')}
          class="border-2 border-white text-white hover:bg-white hover:text-navy-dark font-bold text-lg px-8 py-4 rounded-lg transition-colors"
        >
          View Our Services
        </a>
      </div>
    </div>
  </section>

  <!-- ============ TRUST BADGES ============ -->
  <section class="bg-navy py-10">
    <div class="max-w-6xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div>
        <p class="text-gold font-heading font-bold text-3xl">10+</p>
        <p class="text-gray-300 text-sm mt-1">Years Experience</p>
      </div>
      <div>
        <p class="text-gold font-heading font-bold text-3xl">500+</p>
        <p class="text-gray-300 text-sm mt-1">Projects Completed</p>
      </div>
      <div>
        <p class="text-gold font-heading font-bold text-3xl">100%</p>
        <p class="text-gray-300 text-sm mt-1">Family Owned</p>
      </div>
      <div>
        <p class="text-gold font-heading font-bold text-3xl">5★</p>
        <p class="text-gray-300 text-sm mt-1">Customer Rated</p>
      </div>
    </div>
  </section>

  <!-- ============ SERVICES CARDS ============ -->
  <section class="py-20 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-gold font-medium uppercase tracking-widest text-sm mb-2">What We Do</p>
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-navy">Our Services</h2>
        <p class="text-gray-600 mt-4 max-w-2xl mx-auto">
          From concept to completion, we bring your outdoor vision to life with quality materials
          and old-school craftsmanship.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((svc) => (
          <a
            href={link('/services')}
            class="group bg-white rounded-xl p-6 shadow-md hover:shadow-xl border border-gray-100 hover:border-gold transition-all duration-300 hover:-translate-y-1"
          >
            <div class="text-gold mb-4">
              <ServiceIcon name={svc.icon} class="w-12 h-12" />
            </div>
            <h3 class="font-heading font-bold text-lg text-navy mb-2 group-hover:text-gold transition-colors">
              {svc.title}
            </h3>
            <p class="text-gray-600 text-sm leading-relaxed">{svc.short}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA BAND ============ -->
  <section class="bg-gold py-14">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-navy-dark mb-4">
        Ready to Transform Your Property?
      </h2>
      <p class="text-navy/80 text-lg mb-8 max-w-2xl mx-auto">
        Get a free, no-obligation estimate from our team. We'll visit your property, discuss your
        vision, and deliver a detailed quote — all at no cost.
      </p>
      <a
        href={link('/contact')}
        class="inline-block bg-navy-dark hover:bg-navy text-white font-bold text-lg px-10 py-4 rounded-lg transition-colors shadow-lg"
      >
        Get Your Free Estimate
      </a>
    </div>
  </section>

  <!-- ============ GALLERY PREVIEW ============ -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-gold font-medium uppercase tracking-widest text-sm mb-2">Our Work</p>
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-navy">Recent Projects</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {galleryImages.map((img) => (
          <div class="rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300">
            <img
              src={link(img.src)}
              alt={img.alt}
              class="w-full h-64 object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <a
          href={link('/gallery')}
          class="inline-block border-2 border-navy text-navy hover:bg-navy hover:text-white font-bold px-8 py-3 rounded-lg transition-colors"
        >
          View Full Gallery
        </a>
      </div>
    </div>
  </section>

  <!-- ============ ABOUT TEASER ============ -->
  <section class="py-20 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <img
            src={link('/img/services/company-sign.jpg')}
            alt="M & J Masonry company sign"
            class="rounded-xl shadow-lg w-full h-auto object-cover"
            loading="lazy"
          />
        </div>
        <div>
          <p class="text-gold font-medium uppercase tracking-widest text-sm mb-2">Who We Are</p>
          <h2 class="font-heading font-bold text-3xl md:text-4xl text-navy mb-6">
            A Family Business with Deep Roots
          </h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            M &amp; J Masonry is a family-owned and operated hardscape company based in
            Rockland, Massachusetts. We've been serving the South Shore community for over a
            decade, building lasting relationships one project at a time.
          </p>
          <p class="text-gray-700 leading-relaxed mb-8">
            Every member of our crew takes personal pride in the work we do. From the first
            consultation to the final walkthrough, you'll deal directly with the owners — because
            your project matters to us as much as it matters to you.
          </p>
          <a
            href={link('/about')}
            class="inline-block bg-navy hover:bg-navy-light text-white font-bold px-8 py-3 rounded-lg transition-colors"
          >
            Learn More About Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ BOTTOM CTA ============ -->
  <section class="bg-navy-dark py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-white mb-4">
        Let's Build Something Great Together
      </h2>
      <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">
        Call us today or fill out our quick form for a free estimate. No pressure, no gimmicks —
        just honest work and fair prices.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={callLink}
          class="bg-gold hover:bg-gold-bright text-navy-dark font-bold text-lg px-8 py-4 rounded-lg transition-colors shadow-lg"
        >
          Call {phoneDisplay}
        </a>
        <a
          href={link('/contact')}
          class="border-2 border-gold text-gold hover:bg-gold hover:text-navy-dark font-bold text-lg px-8 py-4 rounded-lg transition-colors"
        >
          Request a Free Estimate
        </a>
      </div>
    </div>
  </section>
</Layout>
