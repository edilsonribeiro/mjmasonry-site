---
import Layout from '../layouts/Layout.astro';
import { callLink, phoneDisplay } from '../data/contact';
import { link } from '../lib/url';
---

<Layout
  title="About Us — Family-Owned Masonry in Rockland, MA"
  description="Meet M & J Masonry: a family-owned and operated hardscape company serving the South Shore of Massachusetts for over a decade. Honest work, fair prices, lasting results."
>
  <!-- Page Header -->
  <section class="bg-navy-dark py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-gold font-medium uppercase tracking-widest text-sm mb-2">Who We Are</p>
      <h1 class="font-heading font-extrabold text-4xl md:text-5xl text-white mb-4">
        About M &amp; J Masonry
      </h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">
        A family-owned hardscape and masonry company serving Rockland, MA and the South Shore since day one.
      </p>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-20 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <img
            src={link('/img/logo-mj.png')}
            alt="M & J Masonry logo"
            class="w-full h-auto max-w-md mx-auto object-contain"
          />
        </div>
        <div>
          <h2 class="font-heading font-bold text-3xl text-navy mb-6">Our Story</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            M &amp; J Masonry was founded on a simple principle: do great work, treat people
            right, and never cut corners. As a family business, we put our name on every project
            we complete — and that means we hold ourselves to the highest standard.
          </p>
          <p class="text-gray-700 leading-relaxed mb-4">
            Based in Rockland, Massachusetts, we serve homeowners and businesses across the
            entire South Shore region. From building retaining walls that stand the test of time
            to crafting walkways that transform a home's curb appeal, we approach every project
            with the same dedication and attention to detail.
          </p>
          <p class="text-gray-700 leading-relaxed">
            When you hire M &amp; J Masonry, you work directly with the owners. There's no
            middleman, no runaround. We show up on time, communicate clearly, and deliver results
            that speak for themselves.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-gold-dark font-medium uppercase tracking-widest text-sm mb-2">Our Values</p>
        <h2 class="font-heading font-bold text-3xl md:text-4xl text-navy">Why Choose Us</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-cream rounded-xl p-8 text-center border border-gray-100">
          <div class="bg-navy w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-xl text-navy mb-3">Family Owned &amp; Operated</h3>
          <p class="text-gray-600 leading-relaxed">
            We're not a franchise or a faceless company. You'll deal directly with the owners
            from estimate to completion. Your satisfaction is our reputation.
          </p>
        </div>

        <div class="bg-cream rounded-xl p-8 text-center border border-gray-100">
          <div class="bg-navy w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-xl text-navy mb-3">Quality Craftsmanship</h3>
          <p class="text-gray-600 leading-relaxed">
            We use only premium materials and proven techniques. Every project is built to
            withstand New England's toughest weather — for years to come.
          </p>
        </div>

        <div class="bg-cream rounded-xl p-8 text-center border border-gray-100">
          <div class="bg-navy w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-xl text-navy mb-3">Fair &amp; Honest Pricing</h3>
          <p class="text-gray-600 leading-relaxed">
            No hidden fees, no surprise charges. We provide detailed written estimates and stick
            to them. What we quote is what you pay.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-gold-dark font-medium uppercase tracking-widest text-sm mb-2">Service Area</p>
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-navy mb-6">
        Proudly Serving the South Shore
      </h2>
      <p class="text-gray-700 leading-relaxed mb-6 max-w-2xl mx-auto">
        Based in Rockland, MA, we serve homeowners and businesses throughout the South Shore
        including Hingham, Weymouth, Braintree, Quincy, Norwell, Hanover, Marshfield, Scituate,
        Pembroke, Duxbury, Plymouth, and surrounding communities.
      </p>
      <p class="text-gray-700 leading-relaxed max-w-2xl mx-auto">
        Not sure if we serve your area? Give us a call — we're always happy to talk.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy-dark py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-white mb-4">
        Let's Talk About Your Project
      </h2>
      <p class="text-gray-300 text-lg mb-8">
        Reach out today for a free estimate. We'd love to hear about your vision.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={callLink}
          class="bg-gold hover:bg-gold-bright text-navy-dark font-bold text-lg px-8 py-4 rounded-lg transition-colors shadow-lg"
        >
          Call {phoneDisplay}
        </a>
        <a
          href={link('/contact')}
          class="border-2 border-gold text-gold hover:bg-gold hover:text-navy-dark font-bold text-lg px-8 py-4 rounded-lg transition-colors"
        >
          Request a Free Estimate
        </a>
      </div>
    </div>
  </section>
</Layout>
