---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { link } from '../lib/url';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'M & J Masonry — Family-owned masonry and hardscape company in Rockland, MA. Stone walls, walkways, patios, steps, and more. Built by Family. Built to Last.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href={link('/favicon-32x32.png')} />
    <link rel="icon" type="image/png" sizes="192x192" href={link('/favicon-192x192.png')} />
    <link rel="apple-touch-icon" sizes="180x180" href={link('/apple-touch-icon.png')} />

    <!-- Google Fonts: Inter + Poppins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <title>{title} | M &amp; J Masonry</title>
  </head>
  <body class="bg-cream text-navy font-sans text-base antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  ::selection {
    background-color: #C9A84C;
    color: #1B2A4A;
  }

  :focus-visible {
    outline: 2px solid #C9A84C;
    outline-offset: 2px;
  }
</style>
